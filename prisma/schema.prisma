generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  gridSlots     GridSlot[]
  userGrid      UserGrid?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App Models
model UserGrid {
  id          String @id @default(cuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemsData   String // JSON stringified array of SlotItem
  profileData String? // JSON stringified profile data
}

model GridSlot {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  position Int // 0-8 for the 3x3 grid
  type     String // "image" | "placeholder"

  metadata PostMetadata?
  media    Media?

  @@unique([userId, position])
}

model PostMetadata {
  id         String   @id @default(cuid())
  gridSlotId String   @unique
  gridSlot   GridSlot @relation(fields: [gridSlotId], references: [id], onDelete: Cascade)

  caption       String?
  audioTrack    String?
  contentType   String? // "Post", "Reel", "Carousel", "Story"
  scheduledTime DateTime?
}

model Media {
  id         String   @id @default(cuid())
  gridSlotId String   @unique
  gridSlot   GridSlot @relation(fields: [gridSlotId], references: [id], onDelete: Cascade)

  url         String?
  hexColor    String? @default("#fdfbfb") // soft pastel white default
  overlayText String?
}
