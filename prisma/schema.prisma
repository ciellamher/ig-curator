generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  gridSlots     GridSlot[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App Models
model GridSlot {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  position Int // 0-8 for the 3x3 grid
  type     String // "image" | "placeholder"

  metadata PostMetadata?
  media    Media?

  @@unique([userId, position])
}

model PostMetadata {
  id         String   @id @default(cuid())
  gridSlotId String   @unique
  gridSlot   GridSlot @relation(fields: [gridSlotId], references: [id], onDelete: Cascade)

  caption       String?   @db.Text
  audioTrack    String?
  contentType   String? // "Post", "Reel", "Carousel", "Story"
  scheduledTime DateTime?
}

model Media {
  id         String   @id @default(cuid())
  gridSlotId String   @unique
  gridSlot   GridSlot @relation(fields: [gridSlotId], references: [id], onDelete: Cascade)

  url         String?
  hexColor    String? @default("#fdfbfb") // soft pastel white default
  overlayText String?
}
